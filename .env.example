# TriageFlow Environment Variables
# Copy this file to .env and fill in your values

# Required: LLM API endpoint (OpenAI-compatible)
API_BASE_URL=https://api-inference.huggingface.co/v1

# Required: Model identifier
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# Required: API key / Hugging Face token
HF_TOKEN=hf_your_token_here

# Optional: Random seed for reproducibility (default: 42)
SEED=42

# Optional: Override max steps for debugging
MAX_STEPS_OVERRIDE=

# Optional: Run only a specific task (default: run all)
# Values: ticket_classification, ticket_routing, policy_triage
TASK_NAME=

# Optional: Docker image name for local testing
LOCAL_IMAGE_NAME=triageflow
